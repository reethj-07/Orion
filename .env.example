# Application
APP_NAME=Orion
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_USER=orion
POSTGRES_PASSWORD=orion
POSTGRES_DB=orion
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://orion:orion@localhost:5432/orion

# MongoDB
MONGO_USER=orion
MONGO_PASSWORD=orion
MONGO_PORT=27017
MONGODB_URI=mongodb://orion:orion@localhost:27017/?authSource=admin
MONGODB_DB=orion

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# LLM (configure one or both)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
LLM_PROVIDER=openai

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Web research
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Reranking (optional)
COHERE_API_KEY=

# CORS / Frontend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000
API_PORT=8000

# Cookies (set to true in production behind HTTPS)
COOKIE_SECURE=false

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute

# Shared ingest storage (mounted in Docker)
INGEST_STORAGE_DIR=/tmp/orion-ingest
